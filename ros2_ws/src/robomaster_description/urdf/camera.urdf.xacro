<?xml version="1.0"?>

<robot xmlns:xacro="http://playerstage.sourceforge.net/gazebo/xmlschema/#xacro">

  <xacro:macro name="camera" params="tf_prefix='' mount='' camera_yaw=0.0 sim:=false">

    <link name="${tf_prefix}camera_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="0.001" />
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
      </inertial>
      <visual name="camera">
        <origin xyz="7.15e-05 0 -0.0004056" rpy="0 -1.7453293 0" />
        <geometry>
          <mesh filename="package://robomaster_description/meshes/camera.dae"
            scale="1.0 1.0 1.0000001" />
        </geometry>
        <material name="metal" />
      </visual>
    </link>

    <link name="${tf_prefix}camera_optical_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="0.001" />
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
      </inertial>
    </link>


    <xacro:if value="${mount == 'arm'}">
      <joint name="${tf_prefix}camera_joint" type="fixed">
        <origin xyz="0.0053865 -0.0195698 0.0473739" rpy="0 1.6898531 ${camera_yaw}" />
        <parent link="${tf_prefix}arm_2_link" />
        <child link="${tf_prefix}camera_link" />
      </joint>
    </xacro:if>

    <xacro:if value="${mount == 'gimbal'}">
      <joint name="${tf_prefix}camera_joint" type="fixed">
        <origin xyz="0.0728 0.0 0.0315" rpy="0 1.5708 0" />
        <parent link="${tf_prefix}blaster_link" />
        <child link="${tf_prefix}camera_link" />
      </joint>
    </xacro:if>

    <joint name="${tf_prefix}camera_optical_joint" type="fixed">
      <!-- <origin xyz="0.002 0.00 0.004" rpy="0.0872663 0 ${-pi/2}"/> -->
      <!-- <origin xyz="0.002 0.00 0.004" rpy="0.0072663 0 ${-pi/2}"/> -->
      <origin xyz="0.002 0.00 0.004" rpy="0.041623 0 ${-pi/2}" />
      <parent link="${tf_prefix}camera_link" />
      <child link="${tf_prefix}camera_optical_link" />
    </joint>


    <!-- <joint name="camera_optical_link" type="fixed">
      <origin xyz="0 0 0" rpy="0 -0.0872663 0"/>
      <parent link="camera_link"/>
      <child link="camera_optical_link"/>
    </joint> -->

    <!-- Topics match camera_node.py's defaults so apriltag_node can't tell sim
         from the real stream. On camera_optical_link because Gazebo emits the
         optical convention (Z forward), which apriltag pose assumes. -->
    <xacro:if value="${sim}">
      <!-- sdformat lumps fixed-joint children into their parent, which deletes
           camera_optical_link. The sensor itself survives that, but its frame
           doesn't - and apriltag poses are only correct against the optical
           frame. Verified: without this, `ign sdf -p` emits no
           <link name='camera_optical_link'>. -->
      <gazebo reference="${tf_prefix}camera_optical_joint">
        <preserveFixedJoint>true</preserveFixedJoint>
        <disableFixedJointLumping>true</disableFixedJointLumping>
      </gazebo>

      <gazebo reference="${tf_prefix}camera_optical_link">
        <sensor name="camera" type="camera">
          <camera>
            <!-- ~74 deg, approximating the EP's real stream. Gazebo derives
                 camera_info from this, so sim needs no calibration. -->
            <horizontal_fov>1.2915</horizontal_fov>
            <image>
              <width>1280</width>
              <height>720</height>
              <format>R8G8B8</format>
            </image>
            <clip>
              <near>0.05</near>
              <far>30.0</far>
            </clip>
          </camera>
          <always_on>1</always_on>
          <update_rate>30</update_rate>
          <visualize>false</visualize>
          <topic>camera/image_raw</topic>
          <gz_frame_id>${tf_prefix}camera_optical_link</gz_frame_id>
        </sensor>
      </gazebo>
    </xacro:if>

  </xacro:macro>
</robot>